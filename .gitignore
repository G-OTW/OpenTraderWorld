# ── Secrets & config (M3: config files kept secret) ──────────────────────────
.env
.env.*
!.env.example
*.local
secrets/
**/secrets/
*.key
*.pem
*.secret
dns.env
# Demo sandbox env (throwaway values + the $0-credit LLM key) — only the .example ships.
demo.env
# User-managed at runtime (Settings → Network rewrites it). Not tracked, so
# `git reset --hard` on update never clobbers the operator's chosen bind/port/domain.
network.env

