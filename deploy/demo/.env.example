# Demo sandbox env — every value here is THROWAWAY. Never copy anything from deploy/.env.
#   cp demo.env.example .env && edit     (compose auto-loads deploy/demo/.env)

# Postgres password for the demo stack only (generate: openssl rand -hex 24).
POSTGRES_PASSWORD=

# AEAD master key for secrets at rest — the demo stores no real secrets, but core
# requires one (generate: openssl rand -hex 32).
OTW_SECRET_KEY=

# OpenRouter API key from a DEDICATED account with ZERO purchased credits.
# Free models (ids ending in `:free`) work; paid models 402. Leave empty to run the
# demo without the AI agent.
OTW_DEMO_LLM_KEY=

# AlphaVantage API key for the seeded "Market news" feed (free tier at
# alphavantage.co/support/#api-key). Read only by `--seed-demo`, which seals it into
# feed_secrets — it is never stored in the seed SQL or the repo. Leave empty to keep
# that one feed disabled; the Reuters/Fed/ECB RSS feeds need no credential.
# The free tier allows 25 requests/day, so the feed polls hourly.
OTW_DEMO_AV_KEY=

# OTW_LOG=info
