# ─────────────────────────────────────────────────────────────────────────────
# OpenTraderWorld — environment configuration
#
# Copy this file to `.env` in the same directory and fill in real values.
# NEVER commit `.env` — it is gitignored (M3: config files kept secret).
# ─────────────────────────────────────────────────────────────────────────────

# ── Core service ─────────────────────────────────────────────────────────────
# Address the core HTTP/WS API binds to inside its container.
OTW_CORE_HOST=0.0.0.0
OTW_CORE_PORT=8080
# Log level: trace | debug | info | warn | error
OTW_LOG=info

# ── PostgreSQL (durable data: modules, jobs, notes/doc page) ──────────────────
POSTGRES_USER=otw
POSTGRES_PASSWORD=change_me_in_env
POSTGRES_DB=opentraderworld
# Connection string the core uses (host = the compose service name "postgres").
DATABASE_URL=postgres://otw:change_me_in_env@postgres:5432/opentraderworld

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign sessions. Generate a strong random value (setup.sh does this).
SESSION_SECRET=change_me_in_env

# ── Secrets encryption (feed API keys/tokens at rest) ────────────────────────
# Master key for AEAD encryption of feed secrets. Generate a strong random value
# (setup.sh does this). Keep it STABLE — rotating it makes stored feed secrets
# unreadable.
OTW_SECRET_KEY=change_me_in_env

# ── FinanceDatabase module (instrument catalog) ──────────────────────────────
# On module install, the core downloads a zstd-compressed catalog archive (~15 MB)
# and bulk-loads it into Postgres. Build/publish the archive with
# `scripts/build-findb.sh` (see comments there).
#
# Where to fetch the archive from. Three forms are supported:
#   - A GitHub Release **API asset URL** (works for private repos with GITHUB_TOKEN):
#       https://api.github.com/repos/<owner>/<repo>/releases/assets/<ASSET_ID>
#   - A public browser asset URL (no token needed once the repo is public).
#   - A local path or file:// URI readable inside the core container (offline testing).
# Leave blank to use the built-in default (public release URL).
FINDB_ARCHIVE_URL=
# Version tag recorded with the imported dataset (any short string).
FINDB_ARCHIVE_VERSION=findb-data
# Token used to download the archive from a PRIVATE GitHub repo. Needs `contents:read`
# (a fine-grained PAT scoped to this repo, or a classic PAT with `repo`). Remove once
# the repo is public. Keep this secret — never commit it.
GITHUB_TOKEN=

# ── Community Docs submissions ───────────────────────────────────────────────
# OPTIONAL. Doc submissions from the editor work without it: the review website
# accepts anonymous submissions (rate-limited per IP, human-reviewed before publish).
# Set a bearer token only if the review site gave you one (marks this instance as
# trusted). Stays server-side, NEVER shipped to the frontend.
DOC_SUBMISSION_TOKEN=

# ── Reverse proxy / public exposure ──────────────────────────────────────────
# Network exposure (bind interface, port, domain) is NOT set here. It lives in the
# secret-free `network.env` and is managed in-app from Settings → Network. Default is
# localhost-only on :5454. After changing it there, run `docker compose up -d` to apply.
